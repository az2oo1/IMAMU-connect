generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  passwordHash  String?
  studentEmail  String?   @unique
  googleId      String?   @unique
  googleEmail   String?   @unique
  name          String?
  avatarUrl     String?
  bannerUrl     String?
  bio           String?
  
  role          String    @default("USER") // USER, ADMIN, NEWS_WRITER
  isBanned      Boolean   @default(false)
  isSuspended   Boolean   @default(false)
  suspensionExpires DateTime?

  links         UserLink[]
  articles      NewsArticle[]
  messages      Message[]
  deletedMessages Message[] @relation("MessageDeletedBy")
  logs          Log[]
  
  adminOfGroups Group[]   @relation("GroupAdmins")
  memberOfGroups Group[]  @relation("GroupMembers")

  // New relations from user schema
  posts            Post[]
  comments         Comment[]
  enrollments      Enrollment[]
  clubMemberships  ClubMember[]
  aiChats          AiInteraction[]
  notifications    Notification[]
  uploadedFiles    AcademicFile[] @relation("FileUploader")
  approvedFiles    AcademicFile[] @relation("FileApprover")
  filedReports     Report[]       @relation("UserFiledReports")
  adminNotesWritten Report[]      @relation("ReportAdminNoteAuthor")

  createdAt     DateTime  @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // MENTION, REPORT_ANSWER, SYSTEM
  content   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Report {
  id          String   @id @default(uuid())
  reporterId  String
  reporter    User     @relation("UserFiledReports", fields: [reporterId], references: [id])
  reportedId  String?
  type        String   // MESSAGE, NEWS, FILE, USER, CLUB
  contentId   String?
  reason      String
  status      String   @default("PENDING") // PENDING, RESOLVED, DISMISSED
  adminNote   String?
  adminNoteAuthorId String?
  adminNoteAuthor User? @relation("ReportAdminNoteAuthor", fields: [adminNoteAuthorId], references: [id])
  resolutionMessage String? // New: Message shown to the reporter
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
}

model UserLink {
  id        String   @id @default(uuid())
  url       String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NewsArticle {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  content     String
  photoUrl    String?
  tag         String?
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  clubId      String?
  club        Club?    @relation(fields: [clubId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Course {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  avatarUrl   String?
  bannerUrl   String?
  tags        String?
  
  files       AcademicFile[]
  folders     Folder[]
  groups      Group[]
  enrollments Enrollment[]
}

model Folder {
  id          String   @id @default(uuid())
  name        String
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Folder?  @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[] @relation("FolderToFolder")
  files       AcademicFile[]
  createdAt   DateTime @default(now())
  order       Int      @default(0)
}

model AcademicFile {
  id          String   @id @default(uuid())
  name        String
  url         String
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  status      String   @default("APPROVED") // APPROVED, PENDING, REJECTED
  isAnonymous Boolean  @default(true)
  uploaderId  String?
  uploader    User?    @relation("FileUploader", fields: [uploaderId], references: [id])
  approverId  String?
  approver    User?    @relation("FileApprover", fields: [approverId], references: [id])
  size        Int?
  createdAt   DateTime @default(now())
  order       Int      @default(0)
}

model Group {
  id          String   @id @default(uuid())
  name        String
  bio         String?
  tags        String?
  avatarUrl   String?
  isDirectMessage Boolean @default(false)
  
  courseId    String?
  course      Course?   @relation(fields: [courseId], references: [id])
  
  admins      User[]   @relation("GroupAdmins")
  members     User[]   @relation("GroupMembers")
  
  messages    Message[]
  
  createdAt   DateTime @default(now())
}

model Message {
  id          String   @id @default(uuid())
  content     String
  
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id])
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  replyToId   String?
  replyTo     Message? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[] @relation("MessageReplies")

  attachmentUrl  String?
  attachmentName String?
  attachmentSize Int?
  attachmentType String?

  deletedForAll Boolean @default(false)
  deletedBy   User[]   @relation("MessageDeletedBy")

  createdAt   DateTime @default(now())
}

model Log {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  details     String?
  createdAt   DateTime @default(now())
}

// ------------------------------------------------------
// 2. Community Feed & Posts
// ------------------------------------------------------
model Post {
  id        String   @id @default(uuid())
  authorId  String
  content   String
  mediaUrl  String?
  postType  String   @default("GENERAL") // GENERAL, QUESTION, ANNOUNCEMENT, MATERIAL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// 3. Academic Integration (Courses)
// ------------------------------------------------------
model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  semester  String   // e.g., "Fall 2026"
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, semester])
}

// ------------------------------------------------------
// 4. Clubs & Activities
// ------------------------------------------------------
model Club {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  avatarUrl   String?
  bannerUrl   String?
  tags        String?
  createdAt   DateTime @default(now())

  members     ClubMember[]
  links       ClubLink[]
  articles    NewsArticle[]
}

model ClubLink {
  id        String   @id @default(uuid())
  url       String
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ClubMember {
  id       String   @id @default(uuid())
  userId   String
  clubId   String
  joinedAt DateTime @default(now())
  isAdmin  Boolean  @default(false)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  club     Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
}

// ------------------------------------------------------
// 6. AI Features (Gemini API Tracking)
// ------------------------------------------------------
model AiInteraction {
  id           String   @id @default(uuid())
  userId       String
  prompt       String
  aiResponse   String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
