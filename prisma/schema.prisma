generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  passwordHash  String?
  studentEmail  String?   @unique
  googleId      String?   @unique
  name          String?
  avatarUrl     String?
  bannerUrl     String?
  bio           String?
  linkedinUrl   String?
  githubUrl     String?
  
  articles      NewsArticle[]
  messages      Message[]
  
  adminOfGroups Group[]   @relation("GroupAdmins")
  memberOfGroups Group[]  @relation("GroupMembers")

  createdAt     DateTime  @default(now())
}

model NewsArticle {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  content     String
  photoUrl    String?
  tag         String?
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Course {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  
  files       AcademicFile[]
  groups      Group[]
}

model AcademicFile {
  id          String   @id @default(uuid())
  name        String
  url         String
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  createdAt   DateTime @default(now())
}

model Group {
  id          String   @id @default(uuid())
  name        String
  bio         String?
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  
  admins      User[]   @relation("GroupAdmins")
  members     User[]   @relation("GroupMembers")
  
  messages    Message[]
  
  createdAt   DateTime @default(now())
}

model Message {
  id          String   @id @default(uuid())
  content     String
  
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id])
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
}
