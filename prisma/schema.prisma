generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  passwordHash  String?
  studentEmail  String?   @unique
  googleId      String?   @unique
  googleEmail   String?   @unique
  name          String?
  avatarUrl     String?
  bannerUrl     String?
  bio           String?
  
  role          String    @default("USER") // USER, ADMIN, NEWS_WRITER
  isBanned      Boolean   @default(false)
  isSuspended   Boolean   @default(false)
  suspensionExpires DateTime?

  links         UserLink[]
  articles      NewsArticle[]
  messages      Message[]
  deletedMessages Message[] @relation("MessageDeletedBy")
  logs          Log[]
  
  adminOfGroups Group[]   @relation("GroupAdmins")
  memberOfGroups Group[]  @relation("GroupMembers")

  // Social & Engagement
  following       UserFollows[] @relation("UserFollowing")
  followers       UserFollows[] @relation("UserFollowers")
  clubFollowing   ClubFollows[] @relation("ClubFollowing")
  savedArticles   SavedArticle[] @relation("UserSavedArticles")

  // New relations from user schema
  posts            Post[]
  comments         Comment[]
  enrollments      Enrollment[]
  clubMemberships  ClubMember[]
  aiChats          AiInteraction[]
  notifications    Notification[]
  uploadedFiles    AcademicFile[] @relation("FileUploader")
  approvedFiles    AcademicFile[] @relation("FileApprover")
  filedReports     Report[]       @relation("UserFiledReports")
  adminNotesWritten Report[]      @relation("ReportAdminNoteAuthor")

  // Forms
  createdForms     Form[]          @relation("FormCreator")
  formSubmissions  FormSubmission[] @relation("FormSubmitter")

  // Organizational Chart Hierarchy
  managerId     String?
  manager       User?    @relation("UserManagement", fields: [managerId], references: [id])
  subordinates  User[]   @relation("UserManagement")
  orgTitle      String?

  createdAt     DateTime  @default(now())

  @@index([username])
  @@index([name])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // MENTION, REPORT_ANSWER, SYSTEM
  content   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Report {
  id          String   @id @default(uuid())
  reporterId  String
  reporter    User     @relation("UserFiledReports", fields: [reporterId], references: [id])
  reportedId  String?
  type        String   // MESSAGE, NEWS, FILE, USER, CLUB
  contentId   String?
  reason      String
  status      String   @default("PENDING") // PENDING, RESOLVED, DISMISSED
  adminNote   String?
  adminNoteAuthorId String?
  adminNoteAuthor User? @relation("ReportAdminNoteAuthor", fields: [adminNoteAuthorId], references: [id])
  resolutionMessage String? // New: Message shown to the reporter
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
}

model UserLink {
  id        String   @id @default(uuid())
  url       String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NewsArticle {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  content     String
  photoUrl    String?  // Main/cover image
  images      String?  // JSON stringified array of multiple image URLs
  tag         String?
  isArchived  Boolean  @default(false)
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  clubId      String?
  club        Club?    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  
  savedBy     SavedArticle[] @relation("ArticleSavedBy")

  createdAt   DateTime @default(now())

  @@index([title])
}

model NewsTag {
  id        String   @id @default(uuid())
  name      String   @unique
}

model Course {
  id               String   @id @default(uuid())
  name             String
  code             String   @unique
  description      String?
  syllabus         String?
  freeResourcesUrl String?
  paidResourcesUrl String?
  avatarUrl        String?
  bannerUrl        String?
  tags             String?
  
  files       AcademicFile[]
  folders     Folder[]
  groups      Group[]
  enrollments Enrollment[]

  @@index([name])
  @@index([code])
}

model Folder {
  id          String   @id @default(uuid())
  name        String
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Folder?  @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[] @relation("FolderToFolder")
  files       AcademicFile[]
  createdAt   DateTime @default(now())
  order       Int      @default(0)
}

model AcademicFile {
  id          String   @id @default(uuid())
  name        String
  url         String
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  status      String   @default("APPROVED") // APPROVED, PENDING, REJECTED
  isAnonymous Boolean  @default(true)
  uploaderId  String?
  uploader    User?    @relation("FileUploader", fields: [uploaderId], references: [id])
  approverId  String?
  approver    User?    @relation("FileApprover", fields: [approverId], references: [id])
  size        Int?
  createdAt   DateTime @default(now())
  order       Int      @default(0)

  @@index([name])
}

model Group {
  id          String   @id @default(uuid())
  name        String
  bio         String?
  tags        String?
  avatarUrl   String?
  isDirectMessage Boolean @default(false)
  
  courseId    String?
  course      Course?   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  admins      User[]   @relation("GroupAdmins")
  members     User[]   @relation("GroupMembers")
  
  messages    Message[]
  
  createdAt   DateTime @default(now())
}

model Message {
  id          String   @id @default(uuid())
  content     String
  
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  replyToId   String?
  replyTo     Message? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[] @relation("MessageReplies")

  attachmentUrl  String?
  attachmentName String?
  attachmentSize Int?
  attachmentType String?

  pollData      String?  // JSON string containing poll configuration and options

  deletedForAll Boolean @default(false)
  deletedBy   User[]   @relation("MessageDeletedBy")

  pinnedUntil DateTime?
  isEdited    Boolean  @default(false)

  createdAt   DateTime @default(now())
}

model Log {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  details     String?
  createdAt   DateTime @default(now())
}

// ------------------------------------------------------
// 2. Community Feed & Posts
// ------------------------------------------------------
model Post {
  id        String   @id @default(uuid())
  authorId  String
  content   String
  mediaUrl  String?
  postType  String   @default("GENERAL") // GENERAL, QUESTION, ANNOUNCEMENT, MATERIAL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// 3. Academic Integration (Courses)
// ------------------------------------------------------
model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  semester  String   // e.g., "Fall 2026"
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, semester])
}

// ------------------------------------------------------
// 4. Clubs & Activities
// ------------------------------------------------------
model Club {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  avatarUrl   String?
  bannerUrl   String?
  tags        String?
  pageViews   Int      @default(0)
  createdAt   DateTime @default(now())

  members     ClubMember[]
  links       ClubLink[]
  articles    NewsArticle[]
  roles       ClubRole[] @relation("ClubRoles")
  imageHistory ClubImageHistory[]
  followers   ClubFollows[] @relation("ClubFollowers")

  @@index([name])
}

model ClubRole {
  id          String   @id @default(uuid())
  clubId      String
  name        String
  permissions String[]
  createdAt   DateTime @default(now())

  club        Club         @relation("ClubRoles", fields: [clubId], references: [id], onDelete: Cascade)
  members     ClubMember[]

  @@unique([clubId, name])
}

model ClubImageHistory {
  id        String   @id @default(uuid())
  clubId    String
  type      String   // 'AVATAR' or 'BANNER'
  url       String
  createdAt DateTime @default(now())
  
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ClubLink {
  id        String   @id @default(uuid())
  url       String
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ClubMember {
  id       String   @id @default(uuid())
  userId   String
  clubId   String
  joinedAt DateTime @default(now())
  isAdmin  Boolean  @default(false)
  roleTitle String?
  roleId   String?
  role     ClubRole? @relation(fields: [roleId], references: [id])

  managerId String?
  manager   ClubMember? @relation("ClubMembershipTree", fields: [managerId], references: [id])
  subordinates ClubMember[] @relation("ClubMembershipTree")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  club     Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
}

// ------------------------------------------------------
// 6. AI Features (Gemini API Tracking)
// ------------------------------------------------------
model AiInteraction {
  id           String   @id @default(uuid())
  userId       String
  prompt       String
  aiResponse   String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// 7. Social & Engagement
// ------------------------------------------------------
model UserFollows {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  
  follower    User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model ClubFollows {
  followerId  String
  clubId      String
  createdAt   DateTime @default(now())
  
  follower    User @relation("ClubFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  club        Club @relation("ClubFollowers", fields: [clubId], references: [id], onDelete: Cascade)

  @@id([followerId, clubId])
}

model SavedArticle {
  userId      String
  articleId   String
  createdAt   DateTime @default(now())
  
  user        User @relation("UserSavedArticles", fields: [userId], references: [id], onDelete: Cascade)
  article     NewsArticle @relation("ArticleSavedBy", fields: [articleId], references: [id], onDelete: Cascade)
  
  @@id([userId, articleId])
}

// ------------------------------------------------------
// 8. Forms & Applications
// ------------------------------------------------------
model Form {
  id          String   @id @default(uuid())
  title       String
  description String?
  entityType  String   // 'club', 'course', 'general'
  entityId    String?
  creatorId   String
  creator     User     @relation("FormCreator", fields: [creatorId], references: [id])
  status      String   @default("DRAFT") // DRAFT, OPEN, CLOSED
  
  allowMultipleSubmissions Boolean @default(true)
  allowResponseEdits       Boolean @default(true)

  pages       FormPage[]
  submissions FormSubmission[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FormPage {
  id          String   @id @default(uuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  title       String?
  description String?
  order       Int      @default(0)
  fields      FormField[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FormField {
  id          String   @id @default(uuid())
  pageId      String
  page        FormPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type        String   // SHORT_TEXT, LONG_TEXT, SINGLE_CHOICE, MULTIPLE_CHOICE, FILE_UPLOAD
  question    String
  description String?
  required    Boolean  @default(false)
  options     String?  // JSON string array for choice types
  order       Int      @default(0)
  answers     FormAnswer[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FormSubmission {
  id          String   @id @default(uuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation("FormSubmitter", fields: [userId], references: [id])
  answers     FormAnswer[]
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, WAITLISTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FormAnswer {
  id           String   @id @default(uuid())
  submissionId String
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fieldId      String
  field        FormField      @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value        String   @db.Text // Can be JSON string for multiple choices or file URLs
}
